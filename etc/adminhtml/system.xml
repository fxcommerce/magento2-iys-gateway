<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
    <system>
        <tab id="fxcommerce" translate="label" sortOrder="980">
            <label>FxCommerce</label>
        </tab>
        <section id="fxcommerce_iys" translate="label" type="text" sortOrder="980"
                 showInDefault="1" showInWebsite="1" showInStore="1">
            <label>IYS Gateway</label>
            <tab>fxcommerce</tab>
            <resource>FxCommerce_IysGateway::config</resource>

            <group id="general" translate="label" type="text" sortOrder="10"
                   showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Store View Connection</label>
                <field id="enabled" translate="label comment" type="select" sortOrder="10"
                       showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Enable IYS Gateway Synchronization</label>
                    <comment>Synchronization starts automatically after a valid access key is saved.</comment>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="access_token" translate="label comment" type="obscure" sortOrder="20"
                       showInDefault="0" showInWebsite="0" showInStore="1">
                    <label>Gateway Access Key</label>
                    <comment>Select a Store View scope and paste the access key generated for that exact Magento store code.</comment>
                    <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                </field>
            </group>

            <group id="phone" translate="label" type="text" sortOrder="15"
                   showInDefault="1" showInWebsite="1" showInStore="1">
                <label>SMS and Call Recipient</label>
                <field id="sms_enabled" translate="label comment" type="select" sortOrder="5"
                       showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Enable SMS Consent</label>
                    <comment>Show and synchronize SMS consent for this store view.</comment>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <depends>
                        <field id="fxcommerce_iys/general/enabled">1</field>
                    </depends>
                </field>
                <field id="call_enabled" translate="label comment" type="select" sortOrder="6"
                       showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Enable Call Consent</label>
                    <comment>Show and synchronize call consent for this store view.</comment>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <depends>
                        <field id="fxcommerce_iys/general/enabled">1</field>
                    </depends>
                </field>
                <field id="source" translate="label comment" type="select" sortOrder="10"
                       showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Phone Number Source</label>
                    <comment>Select where the customer's current GSM number is stored.</comment>
                    <source_model>FxCommerce\IysGateway\Model\Config\Source\PhoneSource</source_model>
                </field>
                <field id="subscriber_field" translate="label comment" type="text" sortOrder="20"
                       showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Newsletter Phone Field</label>
                    <comment>Enter the newsletter_subscriber table field that stores the GSM number. The field supplied by this module is phone_number.</comment>
                    <validate>required-entry validate-code</validate>
                    <depends>
                        <field id="source">subscriber</field>
                    </depends>
                </field>
                <field id="customer_attribute" translate="label comment" type="select" sortOrder="30"
                       showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Customer Phone Attribute</label>
                    <comment>Select the customer attribute that stores the GSM number.</comment>
                    <source_model>FxCommerce\IysGateway\Model\Config\Source\CustomerAttribute</source_model>
                    <validate>required-entry</validate>
                    <depends>
                        <field id="source">customer</field>
                    </depends>
                </field>

                <group id="display" translate="label" type="text" sortOrder="40"
                       showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Display</label>
                    <field id="phone_label" translate="label comment" type="text" sortOrder="10"
                           showInDefault="1" showInWebsite="1" showInStore="1">
                        <label>Phone Number Label</label>
                        <comment>Displayed on the customer Newsletter page.</comment>
                        <config_path>fxcommerce_iys/phone/display/phone_label</config_path>
                    </field>
                    <field id="phone_note" translate="label comment" type="text" sortOrder="20"
                           showInDefault="1" showInWebsite="1" showInStore="1">
                        <label>Phone Number Description</label>
                        <comment>Displayed below the phone number field.</comment>
                        <config_path>fxcommerce_iys/phone/display/phone_note</config_path>
                    </field>
                    <field id="sms_label" translate="label comment" type="text" sortOrder="30"
                           showInDefault="1" showInWebsite="1" showInStore="1">
                        <label>SMS Consent Label</label>
                        <config_path>fxcommerce_iys/phone/display/sms_label</config_path>
                    </field>
                    <field id="call_label" translate="label comment" type="text" sortOrder="40"
                           showInDefault="1" showInWebsite="1" showInStore="1">
                        <label>Call Consent Label</label>
                        <config_path>fxcommerce_iys/phone/display/call_label</config_path>
                    </field>
                </group>
            </group>

            <group id="sync" translate="label" type="text" sortOrder="20"
                   showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Synchronization</label>
                <field id="cron_enabled" translate="label" type="select" sortOrder="10"
                       showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Enable Queue Cron</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="cron_expr" translate="label comment" type="text" sortOrder="20"
                       showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Cron Expression</label>
                    <comment>Default: every 5 minutes.</comment>
                </field>
                <field id="batch_size" translate="label" type="text" sortOrder="30"
                       showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Batch Size</label>
                    <validate>validate-number validate-greater-than-zero</validate>
                </field>
                <field id="max_attempts" translate="label" type="text" sortOrder="40"
                       showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Maximum Retry Attempts</label>
                    <validate>validate-number validate-greater-than-zero</validate>
                </field>
            </group>
        </section>
    </system>
</config>
