<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Store:etc/config.xsd">
    <default>
        <fxcommerce_iys>
            <general>
                <enabled>1</enabled>
                <access_token></access_token>
            </general>
            <sync>
                <cron_enabled>1</cron_enabled>
                <cron_expr>*/5 * * * *</cron_expr>
                <batch_size>100</batch_size>
                <max_attempts>10</max_attempts>
            </sync>
            <phone>
                <sms_enabled>1</sms_enabled>
                <call_enabled>1</call_enabled>
                <source>subscriber</source>
                <subscriber_field>phone_number</subscriber_field>
                <customer_attribute></customer_attribute>
                <display>
                    <phone_label>GSM Number</phone_label>
                    <phone_note>SMS and call permissions apply to this GSM number.</phone_note>
                    <sms_label>I consent to receive commercial SMS messages.</sms_label>
                    <call_label>I consent to receive commercial phone calls.</call_label>
                </display>
            </phone>
        </fxcommerce_iys>
    </default>
</config>
